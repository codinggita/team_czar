{
  "manifest_version": 3,
  "name": "Jarvis AI Browser Companion",
  "version": "2.0.0",
  "description": "An AI companion that reads, explains and discusses the page you're on — voice in, voice out.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "dist/popup.html",
    "default_title": "Jarvis — Open assistant (Ctrl+Shift+J)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-jarvis": {
      "suggested_key": {
        "default": "Ctrl+Shift+J",
        "mac": "Command+Shift+J"
      },
      "description": "Open / close the Jarvis assistant panel"
    }
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:5000/*", "https://*/*", "http://*/*"],
  "web_accessible_resources": [
    {
      "resources": ["dist/content.css", "icons/*.png"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "minimum_chrome_version": "110"
}
