{
  "name": "jarvis-ai-companion-extension",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:content": "vite build --config vite.content.config.js",
    "build:popup": "vite build --config vite.popup.config.js",
    "build": "npm run build:content && npm run build:popup",
    "dev:content": "vite build --config vite.content.config.js --watch",
    "dev:popup": "vite build --config vite.popup.config.js --watch"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^5.4.0"
  }
}
